<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("./partials/head", { title: 'Import Project' }) %>

  <!-- Open Graph / Social Media Tags -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Pitch///asters">
  <meta property="og:title" content="Import Project - Pitch///asters">
  <meta property="og:description" content="Import your project from Devpost or enter details manually.">
  <meta property="og:image" content="https://pitchmasters.club/og-image.png">
  <meta property="og:url" content="https://pitchmasters.club/import">
  <meta name="twitter:card" content="summary_large_image">
</head>
<body>
  <%- include("./partials/header") %>

  <main id="project-main">
    <a href="/" class="back-link">← Back to Projects</a>

    <section id="project-header">
      <h2 id="page-title">Import a Project</h2>
      <p class="page-subtitle">Import a project from Devpost or enter details manually to practice pitching it.</p>
    </section>

    <section id="import-section">
      <div class="import-method" id="devpost-import">
        <h3>Import from Devpost</h3>
        <p class="method-description">Paste your Devpost project URL to automatically import the details.</p>
        <form id="devpost-form">
          <div class="form-group">
            <label for="devpost-url">Devpost URL</label>
            <input type="url" id="devpost-url" name="devpostUrl" required placeholder="https://devpost.com/software/your-project">
          </div>
          <button type="submit" class="btn btn-primary">Import from Devpost</button>
        </form>
        <div id="devpost-status" class="import-status"></div>
      </div>

      <div class="import-divider">
        <span>or</span>
      </div>

      <div class="import-method" id="manual-import">
        <h3>Enter Manually</h3>
        <p class="method-description">Fill in the pitch details yourself.</p>
        <form id="manual-form">
          <div class="form-group">
            <label for="title">Project Title</label>
            <input type="text" id="title" name="title" required placeholder="e.g., Bugout">
          </div>

          <div class="form-group">
            <label for="description">Short Description</label>
            <textarea id="description" name="description" rows="2" required placeholder="One sentence about what this project does..."></textarea>
          </div>

          <div class="form-group">
            <label for="story">Full Story (optional)</label>
            <textarea id="story" name="story" rows="4" placeholder="More detailed explanation..."></textarea>
          </div>

          <div class="form-group">
            <label for="videoUrl">YouTube Video URL (optional)</label>
            <input type="url" id="videoUrl" name="videoUrl" placeholder="https://youtube.com/watch?v=...">
          </div>

          <div class="form-group">
            <label for="githubUrl">GitHub (optional)</label>
            <input type="url" id="githubUrl" name="githubUrl" placeholder="https://github.com/...">
          </div>

          <div class="form-group">
            <label for="websiteUrl">Website (optional)</label>
            <input type="url" id="websiteUrl" name="websiteUrl" placeholder="https://...">
          </div>

          <div class="form-group">
            <label for="provenanceUrl">Source URL (optional)</label>
            <input type="url" id="provenanceUrl" name="provenanceUrl" placeholder="https://devpost.com/software/...">
          </div>

          <button type="submit" class="btn btn-primary">Create Project</button>
        </form>
      </div>
    </section>
  </main>

  <script src="/import.js"></script>
  <%- include("./partials/footer") %>
</body>
</html>
