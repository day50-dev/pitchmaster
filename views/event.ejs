<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Event - Pitch///asters</title>
  
  <!-- Open Graph / Social Media Tags -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Pitch///asters">
  <meta property="og:title" content="Event - Pitch///asters">
  <meta property="og:description" content="Hackathon event details and attendees.">
  <meta property="og:image" content="https://pitchmasters.club/og-image.png">
  <meta property="og:url" content="https://pitchmasters.club">
  <meta name="twitter:card" content="summary_large_image">
  
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fjalla+One&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
  <%- include("./partials/header") %>

  <main id="event-main" class="container">
    <a href="/" class="back-link">← Back to Events</a>

    <section id="event-header">
      <div class="event-cover-image" id="event-cover"></div>
      <div class="event-info">
        <h1 id="event-title">Loading...</h1>
        <p class="event-date" id="event-date"></p>
        <p class="event-description" id="event-description"></p>
        <div class="event-actions">
          <a id="event-luma-link" href="#" target="_blank" class="btn btn-primary">View on Luma</a>
          <button id="event-attend-btn" class="btn btn-secondary">I'm going</button>
        </div>
        <p class="attendee-count"><span id="attendee-count">0</span> people attending</p>
      </div>
    </section>

    <section id="attendees-section">
      <h3>Attendees (<span id="attendees-count">0</span>)</h3>
      <div id="attendees-list" class="attendees-grid"></div>
    </section>

    <section id="meetups-section">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>Meetups</h3>
        <button id="add-meetup-btn" class="btn btn-secondary">Add Meetup</button>
      </div>
      <div id="meetups-list"></div>
    </section>
  </main>

  <!-- Meetup Modal -->
  <div id="meetup-modal" class="modal fade" tabindex="-1" aria-labelledby="meetupModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="meetupModalLabel">Add Meetup</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p class="step-hint">Where should pitchmasters meet up?</p>
          <form id="meetup-form">
            <div class="form-group">
              <label for="meetup-location">Location (optional)</label>
              <input type="text" id="meetup-location" name="meetup-location" placeholder="e.g., WeWork, specific coffee shop">
            </div>
            <div class="form-group">
              <label for="meetup-comment">Comment (optional)</label>
              <textarea id="meetup-comment" name="meetup-comment" rows="2" placeholder="Any details about the meetup..."></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Add Meetup</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script src="/event.js"></script>
  <%- include("./partials/footer") %>

  <script>
    document.getElementById('current-year')?.textContent = new Date().getFullYear();
  </script>
</body>
</html>
