<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Settings - Pitch///asters</title>
  
  <!-- Open Graph / Social Media Tags -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Pitch///asters">
  <meta property="og:title" content="Settings - Pitch///asters">
  <meta property="og:description" content="Manage your account settings.">
  <meta property="og:image" content="https://pitchmasters.club/og-image.png">
  <meta property="og:url" content="https://pitchmasters.club/settings">
  <meta name="twitter:card" content="summary_large_image">
  
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fjalla+One&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
  <%- include("./partials/header") %>

  <main id="settings-main" class="container">
    <section id="settings-header">
      <h1>Settings</h1>
      <p class="settings-subtitle">Manage your account settings and preferences.</p>
    </section>

    <section id="account-section" class="settings-section">
      <h2>Account</h2>
      <div class="settings-card">
        <div class="settings-item">
          <div class="settings-item-info">
            <h3>Username</h3>
            <p id="settings-username" class="settings-item-description"></p>
          </div>
        </div>
        <div class="settings-item">
          <div class="settings-item-info">
            <h3>Display Name</h3>
            <p id="settings-display-name" class="settings-item-description"></p>
          </div>
        </div>
      </div>
    </section>

    <section id="danger-zone" class="settings-section">
      <h2 class="danger-zone-title">⚠️ Danger Zone</h2>
      <div class="settings-card danger-zone-card">
        <div class="settings-item">
          <div class="settings-item-info">
            <h3>Delete Account</h3>
            <p class="settings-item-description">
              Once you delete your account, there is no going back. All your projects, responses, and data will be permanently removed.
            </p>
          </div>
          <button class="btn btn-danger" id="delete-account-btn">Delete Account</button>
        </div>
      </div>
    </section>
  </main>

  <!-- Delete Account Confirmation Modal -->
  <div id="delete-modal" class="modal fade" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="deleteModalLabel">Delete Account?</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p><strong>This action cannot be undone.</strong></p>
          <p>The following will be permanently deleted:</p>
          <ul>
            <li>All your projects and revisions</li>
            <li>All your responses and ratings</li>
            <li>Your profile and account data</li>
          </ul>
          <div class="form-group mt-3">
            <label for="confirm-username">Type your username to confirm:</label>
            <input type="text" id="confirm-username" class="form-control" placeholder="Enter your username">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-danger" id="confirm-delete-btn">Delete My Account</button>
        </div>
      </div>
    </div>
  </div>

  <script src="/settings.js"></script>
  <%- include("./partials/footer") %>
</body>
</html>
