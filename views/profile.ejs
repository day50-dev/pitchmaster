<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("./partials/head", { title: 'Profile' }) %>

  <!-- Open Graph / Social Media Tags -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Pitch///asters">
  <meta property="og:title" content="Profile - Pitch///asters">
  <meta property="og:description" content="View my hackathon projects and pitches.">
  <meta property="og:image" content="https://pitchmasters.club/og-image.png">
  <meta property="og:url" content="https://pitchmasters.club/profile">
  <meta name="twitter:card" content="summary_large_image">
</head>
<body>
  <%- include("./partials/header") %>

  <main id="profile-main" class="container">
    <section id="profile-header">
      <div class="profile-avatar">
        <img id="user-avatar" src="https://github.com/ghost.png" alt="Profile">
      </div>
      <div class="profile-info">
        <h2 id="user-name">Loading...</h2>
        <p id="user-username" class="username"></p>
        <p id="user-bio" class="bio"></p>
      </div>
    </section>

    <section id="my-events-section">
      <div class="section-header d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0">My Events</h3>
      </div>
      <div id="events-list"></div>
    </section>

    <section id="attempts-section">
      <div class="section-header d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0">My Attempts</h3>
      </div>
      <div id="attempts-list"></div>
    </section>

    <section id="user-projects-section">
      <div class="section-header d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0">My Projects</h3>
        <a href="/edit" class="btn btn-primary">+ New Pitch</a>
      </div>
      <div id="projects-list"></div>
    </section>
  </main>

  <%- include("./partials/footer") %>
  <script src="/profile.js"></script>
</body>
</html>
