<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Search - Pitch///asters</title>
  
  <!-- Open Graph / Social Media Tags -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Pitch///asters">
  <meta property="og:title" content="Search - Pitch///asters">
  <meta property="og:description" content="Search projects, events, and users.">
  <meta property="og:image" content="https://pitchmasters.club/og-image.png">
  <meta property="og:url" content="https://pitchmasters.club/search">
  <meta name="twitter:card" content="summary_large_image">
  
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fjalla+One&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
  <%- include("./partials/header") %>

  <main id="search-main" class="container">
    <section id="search-header">
      <h1>Search Results</h1>
      <p class="search-query">Searching for: <strong id="search-term"></strong></p>
    </section>

    <section id="search-results">
      <div class="search-section">
        <h3>Projects</h3>
        <div id="projects-results" class="search-results-grid"></div>
      </div>

      <div class="search-section">
        <h3>Events</h3>
        <div id="events-results" class="search-results-grid"></div>
      </div>

      <div class="search-section">
        <h3>Users</h3>
        <div id="users-results" class="search-results-grid"></div>
      </div>
    </section>

    <section id="no-results" class="hidden">
      <p class="no-results-msg">No results found for "<span id="no-results-term"></span>"</p>
      <p class="no-results-suggestion">Try different keywords or browse <a href="/">recent projects</a> and <a href="/">upcoming events</a>.</p>
    </section>
  </main>

  <script src="/search.js"></script>
  <%- include("./partials/footer") %>

  <script>
    document.getElementById('current-year')?.textContent = new Date().getFullYear();
  </script>
</body>
</html>
