<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Search - Pitch///asters</title>
  
  <!-- Open Graph / Social Media Tags -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Pitch///asters">
  <meta property="og:title" content="Search - Pitch///asters">
  <meta property="og:description" content="Search projects, events, and users.">
  <meta property="og:image" content="https://pitchmasters.club/og-image.png">
  <meta property="og:url" content="https://pitchmasters.club/search">
  <meta name="twitter:card" content="summary_large_image">
  
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fjalla+One&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
  <%- include("./partials/header") %>

  <main id="search-main" class="container py-4">
    <section id="search-header" class="mb-4">
      <h1 class="mb-3">Search</h1>
      <form action="/search" method="GET" class="row g-2">
        <div class="col-12 col-md-8 col-lg-6">
          <input type="text" name="q" id="search-input" class="form-control form-control-lg" placeholder="Search projects, events, users..." autofocus>
        </div>
        <div class="col-auto">
          <button type="submit" class="btn btn-primary btn-lg">Search</button>
        </div>
      </form>
    </section>

    <section id="search-results" class="d-none">
      <p class="search-query mb-4">Results for: <strong id="search-term"></strong></p>
      <div class="search-section mb-4">
        <h3 class="mb-3">Projects</h3>
        <div id="projects-results" class="search-results-grid"></div>
      </div>

      <div class="search-section mb-4">
        <h3 class="mb-3">Events</h3>
        <div id="events-results" class="search-results-grid"></div>
      </div>

      <div class="search-section mb-4">
        <h3 class="mb-3">Users</h3>
        <div id="users-results" class="search-results-grid"></div>
      </div>
    </section>

    <section id="no-results" class="d-none">
      <div class="alert alert-info">
        <p class="mb-2"><strong>No results found</strong> for "<span id="no-results-term"></span>"</p>
        <p class="mb-0">Try different keywords or browse <a href="/">recent projects</a> and <a href="/">upcoming events</a>.</p>
      </div>
    </section>
  </main>

  <script src="/search.js"></script>
  <%- include("./partials/footer") %>
</body>
</html>
