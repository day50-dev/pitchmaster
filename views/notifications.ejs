<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Notifications - Pitch///asters</title>
  
  <!-- Open Graph / Social Media Tags -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Pitch///asters">
  <meta property="og:title" content="Notifications - Pitch///asters">
  <meta property="og:description" content="View your notifications.">
  <meta property="og:image" content="https://pitchmasters.club/og-image.png">
  <meta property="og:url" content="https://pitchmasters.club/notifications">
  <meta name="twitter:card" content="summary_large_image">
  
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fjalla+One&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
  <%- include("./partials/header") %>

  <main id="notifications-main" class="container">
    <section id="notifications-header">
      <div class="d-flex justify-content-between align-items-center">
        <h1>Notifications</h1>
        <button id="mark-all-read-btn" class="btn btn-secondary">Mark all as read</button>
      </div>
    </section>

    <section id="notifications-list">
      <div class="loading-state">Loading notifications...</div>
    </section>

    <section id="no-notifications" class="hidden">
      <p class="no-notifications-msg">No notifications yet</p>
      <p class="no-notifications-suggestion">When someone describes your project or you get a response, you'll see it here.</p>
    </section>
  </main>

  <script src="/notifications.js"></script>
  <%- include("./partials/footer") %>

  <script>
    document.getElementById('current-year')?.textContent = new Date().getFullYear();
  </script>
</body>
</html>
