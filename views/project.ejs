<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("./partials/head", { title: 'Project' }) %>

  <!-- Open Graph / Social Media Tags -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Pitch///asters">
  <meta property="og:title" content="Project - Pitch///asters">
  <meta property="og:description" content="Re-pitch your hackathon projects. Get real feedback.">
  <meta property="og:image" content="https://pitchmasters.club/og-image.png">
  <meta property="og:url" content="https://pitchmasters.club">
  <meta name="twitter:card" content="summary_large_image">

  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
</head>
<body>
  <%- include("./partials/header") %>

  <main id="project-main">
    <a href="/" class="back-link">← Back to Projects</a>

    <section id="project-header">
      <div class="project-cover-image" id="project-cover"></div>
      <div class="project-header-content">
        <h2 id="project-title">Loading...</h2>
        <div class="project-meta">
          <span id="project-author"></span>
          <span id="project-provenance"></span>
        </div>
      </div>
    </section>

    <section id="revision-selector">
      <div class="revision-header">
        <h3>Revisions</h3>
        <button class="btn btn-secondary" id="add-revision-btn">+ Add Revision</button>
      </div>
      <div id="revision-tabs"></div>
    </section>

    <section class="add-revision-section" id="add-revision-section">
      <div class="add-revision-content">
        <h4>Create New Revision</h4>
        <p class="step-hint">Start with the current content and make your improvements. This resets your accuracy counter.</p>
        <form id="revision-form">
          <div class="form-group">
            <label for="rev-description">Short Description</label>
            <textarea id="rev-description" name="description" rows="3" placeholder="Describe your updated pitch..."></textarea>
          </div>
          <div class="form-group">
            <label for="rev-story">Full Story</label>
            <textarea id="rev-story" name="story" rows="6" placeholder="The complete story of your project..."></textarea>
          </div>
          <div class="form-group">
            <label for="rev-video">YouTube Video URL</label>
            <input type="url" id="rev-video" name="videoUrl" placeholder="https://youtube.com/watch?v=...">
          </div>
          <div class="form-group">
            <label for="rev-videoDuration">Presentation Duration</label>
            <select id="rev-videoDuration" name="videoDuration">
              <option value="">-- Select duration --</option>
              <option value="60">1 minute (lightning talk)</option>
              <option value="120">2 minutes</option>
              <option value="180">3 minutes</option>
              <option value="300">5 minutes</option>
              <option value="420">7 minutes</option>
              <option value="600">10 minutes</option>
              <option value="900">15 minutes</option>
            </select>
            <small class="form-hint">What was the time limit for this presentation?</small>
          </div>
          <div class="form-group">
            <label for="rev-github">GitHub URL</label>
            <input type="url" id="rev-github" name="githubUrl" placeholder="https://github.com/...">
          </div>
          <div class="form-group">
            <label for="rev-website">Website URL</label>
            <input type="url" id="rev-website" name="websiteUrl" placeholder="https://...">
          </div>
          <div class="form-actions">
            <button type="button" class="btn btn-secondary" id="cancel-revision-btn">Cancel</button>
            <button type="submit" class="btn btn-primary">Create Revision</button>
          </div>
        </form>
      </div>
    </section>

    <section id="current-revision">
      <div class="revision-content">
        <div id="video-embed-container" class="video-embed hidden"></div>
        <div class="video-duration-badge hidden" id="video-duration-badge">
          <span class="duration-icon">🎬</span>
          <span class="duration-text" id="video-duration-text"></span>
        </div>
        <div class="revision-links">
          <a id="revision-video" href="" target="_blank" class="project-link youtube">Watch Video</a>
          <a id="revision-github" href="" target="_blank" class="project-link github">View Code</a>
          <a id="revision-website" href="" target="_blank" class="project-link website">Visit Site</a>
        </div>

        <div class="revision-description">
          <h3>About</h3>
          <div id="revision-description-text"></div>
        </div>

        <div class="revision-story hidden" id="revision-story-section">
          <h3>Details</h3>
          <div id="revision-story-text"></div>
        </div>
      </div>

      <div class="audience-section" id="audience-section">
        <div class="audience-header">
          <h3>💬 Describe the Product</h3>
        </div>
        <div class="audience-content">
          <p class="audience-pitch">After viewing the pitch, describe what this project does</p>

          <form id="response-form">
            <div class="form-group">
              <label for="feedbackReason">If you didn't finish...</label>
              <select id="feedbackReason" name="feedbackReason">
                <option value="">-- Select a reason --</option>
                <option value="bored">Got bored / lost interest</option>
                <option value="dont-care">Don't care about this problem</option>
                <option value="too-difficult">Too difficult/complicated to understand</option>
                <option value="hard-to-hear">Hard to hear/understand (audio/video issues)</option>
                <option value="not-interesting">Not interesting to me</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="form-group" id="feedback-other-group" style="display: none;">
              <label for="feedbackOther">Please specify</label>
              <input type="text" id="feedbackOther" name="feedbackOther" placeholder="What was the issue?">
            </div>

            <div class="form-group">
              <label for="whatDoesItDo">What does this do?</label>
              <textarea id="whatDoesItDo" name="whatDoesItDo" rows="2" placeholder="Describe what the project is..."></textarea>
            </div>
            <div class="form-group">
              <label for="problemItSolves">What problem does it solve?</label>
              <textarea id="problemItSolves" name="problemItSolves" rows="2" placeholder="What pain point does it address?"></textarea>
            </div>
            <div class="form-group">
              <label for="whoIsItFor">Who is this for?</label>
              <textarea id="whoIsItFor" name="whoIsItFor" rows="2" placeholder="Who is the target audience?"></textarea>
            </div>
            <div class="form-group">
              <label for="howToUse">How do you use it?</label>
              <textarea id="howToUse" name="howToUse" rows="2" placeholder="How would someone use this?"></textarea>
            </div>
            
            
            <div class="form-actions">
              <button type="submit" class="btn btn-primary">Submit</button>
            </div>
          </form>
        </div>
      </div>
    </section>

    <section id="responses-section">
      <h3>Attempted Descriptions (<span id="response-count">0</span>)</h3>
      <div id="responses-list"></div>
    </section>
  </main>

  <script>
    // Show/hide "other" text field
    document.getElementById('feedbackReason')?.addEventListener('change', (e) => {
      const otherGroup = document.getElementById('feedback-other-group');
      otherGroup.style.display = e.target.value === 'other' ? 'block' : 'none';
    });
  </script>

  <%- include("./partials/footer") %>
  <script src="/project.js"></script>
</body>
</html>
